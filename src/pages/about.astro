---
import PageLayout from "@layouts/PageLayout.astro";
import TopLayout from "@layouts/TopLayout.astro";
import BottomLayout from "@layouts/BottomLayout.astro";
import { SITE } from "@consts";

const personJsonLd = {
    "@context": "https://schema.org",
    "@type": "Person",
    name: "Ivan K",
    url: "https://devops.vaka.work",
    jobTitle: "DevOps Engineer",
    description:
        "DevOps-инженер с фокусом на автоматизации инфраструктуры, Kubernetes и облачных технологиях.",
    sameAs: [
        "https://github.com/VizzleTF",
        "https://t.me/gemini_commit",
        "https://vakaf.space/",
    ],
    knowsAbout: [
        "Kubernetes",
        "Terraform",
        "Proxmox",
        "ArgoCD",
        "CI/CD",
        "DevOps",
        "HashiCorp Vault",
        "Prometheus",
        "Grafana",
    ],
};
---

<script type="application/ld+json" set:html={JSON.stringify(personJsonLd)}
></script>

<PageLayout
    title="Об авторе"
    description="Иван K — DevOps-инженер с фокусом на Kubernetes, Terraform, Proxmox и автоматизации инфраструктуры. Автор блога Сказочный девопес."
>
    <TopLayout>
        <div class="animate">
            <div class="page-heading">Об авторе</div>
        </div>
    </TopLayout>
    <BottomLayout>
        <div class="animate">
            <article class="prose dark:prose-invert max-w-none">
                <p>
                    Привет, меня зовут <strong>Иван</strong> — DevOps-инженер с фокусом
                    на автоматизации инфраструктуры, Kubernetes и облачных технологиях.
                </p>
                <p>
                    Этот блог — место, где я делюсь реальным опытом: не теорией
                    из учебников, а практическими решениями из живых проектов.
                </p>

                <h2>Чем я занимаюсь</h2>
                <ul>
                    <li>
                        <strong>Kubernetes &amp; Container Orchestration</strong
                        > — проектирование и поддержка production-кластеров
                    </li>
                    <li>
                        <strong>Infrastructure as Code</strong> — Terraform, Proxmox
                        BPG провайдер, модульная архитектура
                    </li>
                    <li>
                        <strong>CI/CD &amp; GitOps</strong> — ArgoCD, GitHub Actions,
                        автоматизация деплоя
                    </li>
                    <li>
                        <strong>Selfhosted</strong> — домашняя лаборатория на базе
                        Proxmox, Talos Linux, Longhorn
                    </li>
                    <li>
                        <strong>Мониторинг</strong> — Prometheus, Grafana, Alertmanager
                    </li>
                    <li>
                        <strong>Секреты и безопасность</strong> — HashiCorp Vault,
                        External Secrets Operator
                    </li>
                </ul>

                <h2>Проекты</h2>
                <ul>
                    <li>
                        🔧 <strong
                            ><a
                                href="https://marketplace.visualstudio.com/items?itemName=VizzleTF.geminicommit"
                                rel="noopener noreferrer"
                                target="_blank">CommitSage</a
                            >
                        </strong> — VSCode-расширение для автоматической генерации
                        commit-сообщений с помощью Gemini AI
                    </li>
                    <li>
                        🏠 <strong
                            ><a
                                href="https://github.com/VizzleTF/home_proxmox"
                                rel="me noopener noreferrer"
                                target="_blank">Home Proxmox</a
                            >
                        </strong> — Terraform-конфигурация для домашней лабы на Proxmox
                    </li>
                </ul>

                <h2>Контакты</h2>
                <ul>
                    <li>
                        📱 Telegram: <a
                            href="https://t.me/gemini_commit"
                            rel="noopener noreferrer"
                            target="_blank">@gemini_commit</a
                        >
                    </li>
                    <li>
                        💻 GitHub: <a
                            href="https://github.com/VizzleTF"
                            rel="me noopener noreferrer"
                            target="_blank">github.com/VizzleTF</a
                        >
                    </li>
                    <li>
                        📧 Email: <a href="mailto:vizzletf@gmail.com"
                            >vizzletf@gmail.com</a
                        >
                    </li>
                </ul>
            </article>
        </div>
    </BottomLayout>
</PageLayout>
