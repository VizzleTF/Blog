---
import type { CollectionEntry } from "astro:content";
import { formatDate, readingTime } from "@lib/utils";
import { SITE } from "@consts";

type Props = {
  entry: CollectionEntry<"projects"> | CollectionEntry<"blog">;
};

const { entry } = Astro.props;
const { collection, data, body } = entry;
const { title, summary, date, tags } = data;

const updatedDate =
  collection === "blog" && data.updatedDate ? data.updatedDate : null;
const demoUrl = collection === "projects" ? data.demoUrl : null;
const repoUrl = collection === "projects" ? data.repoUrl : null;

const siteUrl = "https://onlyyaml.dev";
const canonicalUrl = `${siteUrl}/${collection}/${entry.slug}/`;
const imageUrl =
  collection === "blog" && data.image
    ? `${siteUrl}${data.image}`
    : `${siteUrl}/open-graph.png`;

const jsonLd =
  collection === "blog"
    ? {
        "@context": "https://schema.org",
        "@type": "BlogPosting",
        headline: title,
        description: summary,
        datePublished: new Date(date).toISOString(),
        dateModified: updatedDate
          ? new Date(updatedDate).toISOString()
          : new Date(date).toISOString(),
        url: canonicalUrl,
        image: imageUrl,
        inLanguage: "ru-RU",
        author: {
          "@type": "Person",
          name: SITE.AUTHOR,
          url: `${siteUrl}/about`,
          sameAs: ["https://github.com/VizzleTF", "https://t.me/gemini_commit"],
        },
        publisher: {
          "@type": "Organization",
          name: SITE.TITLE,
          url: siteUrl,
          logo: {
            "@type": "ImageObject",
            url: `${siteUrl}/favicon.png`,
          },
        },
        keywords: tags?.join(", "),
        mainEntityOfPage: {
          "@type": "WebPage",
          "@id": canonicalUrl,
        },
      }
    : null;
---

{
  jsonLd && (
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  )
}

<div>
  <a
    href={`/${collection}`}
    class="group w-fit px-2.5 py-1.5 gap-1.5 text-xs font-mono uppercase tracking-wider flex items-center border rounded text-dim hover:text-accent hover:border-accent border-black/15 dark:border-white/20 transition-colors duration-300 ease-in-out"
  >
    <svg
      xmlns="http://www.w3.org/2000/svg"
      width="14"
      height="14"
      viewBox="0 0 24 24"
      fill="none"
      stroke-width="2"
      stroke-linecap="round"
      stroke-linejoin="round"
      class="stroke-current"
    >
      <path d="M19 12H5M11 5l-7 7 7 7"></path>
    </svg>
    {collection === "blog" ? "К блогу" : "К проектам"}
  </a>
  <div class="flex flex-wrap font-mono text-[11px] uppercase tracking-[0.12em] text-dim mt-10 gap-x-5 gap-y-2">
    <div class="flex items-center gap-1.5">
      <svg class="size-4 stroke-current">
        <use href="/ui.svg#calendar"></use>
      </svg>
      {formatDate(date)}
    </div>
    {
      updatedDate && (
        <div class="flex items-center gap-1.5">
          <svg class="size-4 stroke-current">
            <use href="/ui.svg#calendar" />
          </svg>
          Обновлено: {formatDate(updatedDate)}
        </div>
      )
    }
    <div class="flex items-center gap-1.5">
      <svg class="size-4 stroke-current">
        <use href="/ui.svg#book-open"></use>
      </svg>
      {readingTime(body)}
    </div>
  </div>
  <h1 class="text-3xl md:text-4xl font-bold tracking-tight text-black dark:text-white mt-3 leading-tight">
    {title}
  </h1>
  <p class="mt-3 text-dim max-w-2xl leading-relaxed">
    {summary}
  </p>
  {tags && tags.length > 0 && (
    <div class="flex flex-wrap gap-x-2 gap-y-1 mt-4 font-mono text-[11px] text-accent">
      {tags.slice(0, 6).map((tag: string) => (
        <span>#{tag}</span>
      ))}
    </div>
  )}
  {
    (demoUrl || repoUrl) && (
      <div class="mt-4 flex flex-wrap gap-2">
        {demoUrl && (
          <a
            href={demoUrl}
            target="_blank"
            class="group flex gap-2 items-center px-3 py-1.5 truncate rounded text-xs md:text-sm lg:text-base border border-black/25 dark:border-white/25 hover:bg-black/5 hover:dark:bg-white/15 blend"
          >
            <svg class="size-4">
              <use
                href="/ui.svg#globe"
                class="fill-current group-hover:fill-black group-hover:dark:fill-white blend"
              />
            </svg>
            <span class="text-current group-hover:text-black group-hover:dark:text-white blend">
              Демо
            </span>
          </a>
        )}
        {repoUrl && (
          <a
            href={repoUrl}
            target="_blank"
            class="group flex gap-2 items-center px-3 py-1.5 truncate rounded text-xs md:text-sm lg:text-base border border-black/25 dark:border-white/25 hover:bg-black/5 hover:dark:bg-white/15 blend"
          >
            <svg class="size-4">
              <use
                href="/ui.svg#link"
                class="fill-current group-hover:fill-black group-hover:dark:fill-white blend"
              />
            </svg>
            <span class="text-current group-hover:text-black group-hover:dark:text-white blend">
              Посмотреть репозиторий
            </span>
          </a>
        )}
      </div>
    )
  }
</div>
