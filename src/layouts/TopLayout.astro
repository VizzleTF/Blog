---
import Container from "@components/Container.astro"
type Size = "sm" | "md" | "lg" | "xl" | "2xl";
const { dense = false, size = "md" } = Astro.props as { dense?: boolean; size?: Size };
---

<div class={`pt-36 pb-5 bg-gradient-to-b ${dense ? 'from-white/20 to-white/85 dark:from-black/20 dark:to-black/85' : 'from-white/10 to-white/75 dark:from-black/10 dark:to-black/75'}`}>
  <Container size={size}>
    <slot/>
  </Container>
</div>
